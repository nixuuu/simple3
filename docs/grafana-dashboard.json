{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Request rate by op",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(simple3_request_duration_seconds_count[1m]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "p50 / p99 latency by op (1 MB GET/PUT etc.)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, operation) (rate(simple3_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{operation}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(simple3_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Ingress / Egress",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(simple3_bytes_received_total[1m])",
          "legendFormat": "ingress"
        },
        {
          "expr": "rate(simple3_bytes_sent_total[1m])",
          "legendFormat": "egress"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "Active connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "simple3_connections_active",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Dead-space ratio per bucket",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "simple3_dead_space_ratio",
          "legendFormat": "{{bucket}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } }
    },
    {
      "title": "Compaction runs / duration",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(simple3_compaction_runs_total[5m])",
          "legendFormat": "runs/s"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(simple3_compaction_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 duration"
        }
      ]
    },
    {
      "title": "Rate-limit drops",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(simple3_rate_limited_total[1m])",
          "legendFormat": "{{protocol}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Segments per bucket",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "simple3_segments_total",
          "legendFormat": "{{bucket}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["simple3", "s3"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "simple3",
  "uid": "simple3-overview",
  "version": 1
}
